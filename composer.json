{
  "name": "acrosswp/acrossai-mcp-manager",
  "description": "AcrossAI MCP Manager - Enable/Disable MCP Adapter Integration",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "WordPress MCP Team",
      "homepage": "https://wordpress.org"
    }
  ],
  "require": {
    "php": ">=7.4",
    "automattic/jetpack-autoloader": "^2.0",
    "wordpress/mcp-adapter": ">=0.4.1",
    "wpboilerplate/wpb-access-control": "dev-main",
    "bshaffer/oauth2-server-php": "^1.14",
    "bshaffer/oauth2-server-httpfoundation-bridge": "^1.7",
    "symfony/http-foundation": "^7.0"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/WordPress/mcp-adapter.git"
    },
    {
      "type": "vcs",
      "url": "https://github.com/WPBoilerplate/wpb-access-control.git"
    }
  ],
  "autoload": {
    "psr-4": {
      "ACROSSAI_MCP_MANAGER\\": "src/"
    },
    "files": [
      "src/Core/polyfills.php"
    ]
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "config": {
    "allow-plugins": {
      "automattic/jetpack-autoloader": true
    }
  }
}